    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "codegen": "pnpm -r --if-present run codegen",
    "ci:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4"
